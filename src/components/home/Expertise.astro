---
import TargetIcon from '@assets/icons/target-fill.svg';
import AccordionItem from '@components/common/AccordionItem.astro';
import { getLabels } from '@i18n/utils';

const labels = getLabels(Astro.currentLocale, 'homeExpertise');
const expertises = labels.expertises;
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="grid gap-12 lg:grid-cols-3 lg:gap-8">
      <div class="flex gap-4">
        <TargetIcon class="fill-primary-500 h-8 w-8 shrink-0 sm:h-10 sm:w-10" aria-hidden="true" />
        <h2 class="text-3xl font-medium tracking-tight sm:text-4xl">{labels.title}</h2>
      </div>
      <div class="lg:col-span-2">
        <dl class="-mt-3" x-data="accordion">
          {
            expertises.map((expertise, index) => (
              <AccordionItem id={expertise.id} index={index}>
                <span slot="header" class="font-medium">
                  {expertise.name}
                </span>
                <div slot="body" class="pr-6 pb-6">
                  <p class="text-muted text-base">{expertise.description}</p>
                </div>
              </AccordionItem>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>
