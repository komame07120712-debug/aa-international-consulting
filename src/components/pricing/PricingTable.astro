---
import CheckboxIcon from '@assets/icons/checkbox-circle-fill.svg';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLabels, defaultLocale } from '@i18n/utils';

const labels = getLabels(Astro.currentLocale, 'pricingTable');
const currentLocale = Astro.currentLocale || defaultLocale;

const pricings = labels.pricings.map((pricing) => ({
  ...pricing,
  actionLink: getRelativeLocaleUrl(currentLocale, '/contact'),
}));

const gridCols: Record<number, string> = { 1: 'lg:grid-cols-1', 2: 'lg:grid-cols-2', 3: 'lg:grid-cols-3' };
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class={`-mt-8 grid items-stretch gap-8 lg:mt-0 ${gridCols[Math.min(pricings.length, 3)]}`}>
      {
        pricings.map((pricing) => (
          <div
            class:list={[
              'relative flex h-full w-full max-w-sm flex-col gap-8 rounded-3xl p-8',
              pricing.isFlagged && 'bg-surface',
            ]}
          >
            <div class="flex-1">
              <h2 class="text-xl font-medium">{pricing.name}</h2>
              <p class="mt-4 flex items-baseline">
                <span class="text-4xl font-medium tracking-tight">{pricing.price}</span>
                <span class="text-muted ml-1 text-sm font-medium">{pricing.periodicity}</span>
              </p>
              <p class="text-muted mt-6">{pricing.description}</p>

              <ul role="list" class="mt-6 space-y-6">
                {pricing.features.map((feature) => (
                  <li class="flex gap-3">
                    <CheckboxIcon class="icon-primary shrink-0" aria-hidden="true" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
            <a href={pricing.actionLink} class="btn-primary w-full">
              {pricing.action}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
