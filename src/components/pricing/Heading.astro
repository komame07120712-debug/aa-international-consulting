---
import { getLabels } from '@i18n/utils';

const labels = getLabels(Astro.currentLocale, 'pricingHeading');
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-4 sm:gap-6">
      <h1 class="text-4xl font-medium tracking-tight sm:text-5xl lg:text-6xl">{labels.title}</h1>
      <p class="text-muted mx-auto max-w-sm text-lg sm:max-w-md sm:text-xl">{labels.description}</p>
    </div>
  </div>
</section>
